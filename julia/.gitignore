# julia/.gitignore
# Track all source code; ignore generated outputs and Julia artefacts.
# Previously this file was just `*` (ignore everything) — now expanded.

# ── Julia artefacts ────────────────────────────────────────────────────────
.julia/
*.ji
*.so

# ── Generated output directories ───────────────────────────────────────────
**/outputs/
**/figures/
**/logs/
**/output_*/

# ── Generated data files ───────────────────────────────────────────────────
*.csv
*.h5
*.hdf5

# ── Committed reference data (override the *.csv rule above) ───────────────
!experiments/test/reference/*.csv

# ── Generated figures ──────────────────────────────────────────────────────
*.pdf
*.png
*.svg
*.eps

# ── Log / scratch ──────────────────────────────────────────────────────────
*.log
